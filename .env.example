# 🛡️ ShadowNet Nexus Configuration v5.0
# Security Note: Do not commit this file to version control

# =============================================================================
# 🔑 CORE AI CONFIGURATION
# =============================================================================
# Get your free API key from: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# Model Selection (Default: gemini-2.5-flash for real-time speed)
# Options: gemini-2.5-flash, gemini-1.5-pro, gemini-1.5-flash
SHADOWNET_MODEL_FAST=gemini-2.5-flash
SHADOWNET_MODEL_INTELLIGENT=gemini-2.5-flash

# =============================================================================
# ⚙️ SYSTEM SETTINGS
# =============================================================================
SHADOWNET_ENVIRONMENT=production
SHADOWNET_LOG_LEVEL=INFO
SHADOWNET_EVIDENCE_PATH=./evidence
EVIDENCE_RETENTION_DAYS=90
AUTO_SNAPSHOT_ENABLED=true

# Toggle AI usage for network verification.
ENABLE_NETWORK_AI=false

# =============================================================================
# 📡 SIEM & INTEGRATIONS
# =============================================================================
# Webhook URL for SIEM or custom monitoring
SIEM_WEBHOOK_URL=

# Splunk HEC
SPLUNK_HEC_URL=https://splunk-server:8088
SPLUNK_HEC_TOKEN=
SPLUNK_VERIFY_SSL=true

# QRadar
QRADAR_API_URL=https://qradar-console
QRADAR_API_TOKEN=

# Elastic Stack
ELASTIC_URL=http://elasticsearch:9200
ELASTIC_API_KEY=

# Syslog
SYSLOG_SERVER=127.0.0.1
SYSLOG_PORT=514

# =============================================================================
# 🔔 ALERTING & NOTIFICATIONS
# =============================================================================
# Slack
SLACK_WEBHOOK_URL=

# Discord
DISCORD_WEBHOOK_URL=

# Email
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_RECIPIENTS=security-alerts@example.com
